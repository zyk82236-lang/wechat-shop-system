<view class="card" wx:if="{{!order && !loading}}">
  <view class="empty">暂无订单详情</view>
</view>

<view wx:if="{{order}}">
  <view class="card">
    <view class="head">
      <text class="order-no">订单号 {{order.orderNo}}</text>
      <text class="status">{{order.statusText}}</text>
    </view>
    <view class="row">商品金额 ¥{{order.itemAmountText}}</view>
    <view class="row">运费 ¥{{order.shippingAmountText}}</view>
    <view class="row total">实付 ¥{{order.amountText}}</view>
  </view>

  <view class="card">
    <view class="section-title">商品清单</view>
    <view class="item" wx:for="{{order.items}}" wx:key="id">
      <view class="item-title">{{item.title}}</view>
      <view class="item-sub">{{item.skuName}} × {{item.quantity}}</view>
      <view class="item-price">¥{{item.amountText}}</view>
    </view>
  </view>

  <view class="card" wx:if="{{order.shipment}}">
    <view class="section-title">物流信息</view>
    <view class="row">快递公司：{{order.shipment.company}}</view>
    <view class="row">单号：{{order.shipment.trackingNo}}</view>
    <view class="row">状态：{{order.shipment.status || 'in_transit'}}</view>
    <view class="section-title track-title">物流轨迹</view>
    <view class="track" wx:for="{{order.tracks}}" wx:key="time">
      <view class="track-time">{{item.time}}</view>
      <view class="track-content">{{item.content}}</view>
    </view>
    <view class="empty" wx:if="{{!order.tracks.length}}">暂无物流轨迹</view>
  </view>

  <view class="card actions">
    <button wx:if="{{order.status === 'pending_payment'}}" bindtap="cancelOrder">取消订单</button>
    <button wx:if="{{order.status === 'shipped'}}" type="primary" bindtap="confirmReceived">确认收货</button>
  </view>
</view>
