<view class="card" wx:if="{{product}}">
  <image src="{{product.cover}}" mode="aspectFill" style="width: 100%; height: 380rpx; border-radius: 14rpx" />
  <view class="title">{{product.title}}</view>
  <view class="subtitle">{{product.subtitle}}</view>

  <view class="sku-title">规格</view>
  <view class="sku-wrap">
    <view
      wx:for="{{product.skus}}"
      wx:key="id"
      class="sku {{skuId===item.id?'active':''}}"
      data-id="{{item.id}}"
      bindtap="pickSku"
    >
      {{item.name}} ¥{{item.priceText}}
    </view>
  </view>

  <view class="actions">
    <button bindtap="addCart">加入购物车</button>
    <button class="btn-primary" bindtap="buyNow">立即购买</button>
  </view>
</view>
