# ===== API runtime =====
PORT=3000
NODE_ENV=production

# ===== Database / Cache =====
DATABASE_URL=mysql://shop_user:shop_password@127.0.0.1:3306/wechat_shop
REDIS_URL=redis://127.0.0.1:6379

# ===== WeChat Pay V3 =====
WECHAT_APP_ID=wx_your_appid
WECHAT_MCH_ID=1900000001
WECHAT_MCH_SERIAL_NO=YOUR_MCH_SERIAL_NO
WECHAT_MCH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"
WECHAT_PAY_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PLATFORM_PUBLIC_KEY\n-----END PUBLIC KEY-----"
WECHAT_PAY_NOTIFY_URL=https://api.your-domain.com/payments/wechat/notify
